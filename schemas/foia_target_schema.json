{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/dataciviclab/data-advocacy/schemas/foia_target_schema.json",
  "title": "FOIA Target Schema",
  "description": "Formato condiviso per l'import di target FOIA in data-advocacy. Prodotto da partecipate-monitor, source-observatory e altre fonti.",
  "type": "object",
  "required": ["fonte", "data_generazione", "targets"],
  "properties": {
    "fonte": {
      "type": "string",
      "description": "Repo o modulo che ha generato il file",
      "examples": ["partecipate-monitor", "source-observatory"]
    },
    "data_generazione": {
      "type": "string",
      "format": "date",
      "description": "Data di generazione del file (ISO 8601)"
    },
    "targets": {
      "type": "array",
      "description": "Elenco dei target FOIA",
      "items": {
        "type": "object",
        "required": ["id", "denominazione", "violazione", "priorita"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identificatore univoco del target (slug)",
            "examples": ["actv-spa", "a2a-spa"]
          },
          "denominazione": {
            "type": "string",
            "description": "Denominazione ufficiale dell'ente/società"
          },
          "pec": {
            "type": "string",
            "format": "email",
            "description": "Indirizzo PEC certificato (da IPA)",
            "examples": ["actv@pec.actv.it"]
          },
          "codice_fiscale": {
            "type": "string",
            "description": "Codice fiscale / partita IVA"
          },
          "sito_web": {
            "type": "string",
            "description": "Sito istituzionale",
            "examples": ["www.actv.it"]
          },
          "categoria": {
            "type": "string",
            "description": "Tipologia ente/società",
            "enum": ["controllo_pubblico", "partecipata", "pa", "gestore_servizio", "altro"]
          },
          "violazione": {
            "type": "string",
            "description": "Tipo di violazione rilevata",
            "enum": [
              "nessuna_sezione",
              "formato_chiuso",
              "dati_mancanti",
              "sezione_incompleta",
              "non_verificabile"
            ]
          },
          "norma_violata": {
            "type": "string",
            "description": "Riferimento normativo violato",
            "examples": ["Art. 2-bis D.Lgs 33/2013", "Art. 7 D.Lgs 33/2013"]
          },
          "priorita": {
            "type": "integer",
            "description": "Priorità FOIA (1=urgente, 2=media, 3=bassa)",
            "minimum": 1,
            "maximum": 3
          },
          "dettaglio": {
            "type": "string",
            "description": "Descrizione del problema rilevato"
          },
          "fonte_dato": {
            "type": "string",
            "description": "Riferimento al dato che ha generato il target",
            "examples": ["scan 2026-07-05", "catalogo 2026-07-05"]
          },
          "metadata": {
            "type": "object",
            "description": "Metadati aggiuntivi (specifici per fonte)",
            "properties": {
              "score_catalogo": {"type": "number", "description": "Score catalogo trasparenza (0-100)"},
              "formati_aperti": {"type": "boolean"},
              "totale_file": {"type": "integer"},
              "regione": {"type": "string"},
              "tipo_controllo": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
